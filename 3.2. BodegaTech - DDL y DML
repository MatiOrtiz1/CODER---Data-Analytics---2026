-- ── SECCIÓN DDL ──────────────────────────

-- Eliminamos la tabla si existe para evitar errores en re-ejecuciones
DROP TABLE IF EXISTS inventario;

-- Creación de la estructura del inventario
CREATE TABLE inventario (
    id_producto INT PRIMARY KEY,
    nombre_producto VARCHAR(100),
    categoria VARCHAR(50),
    -- DECIMAL(10,2) usado para evitar errores de precisión de punto flotante en cálculos financieros.
    precio_unitario DECIMAL(10,2),
    -- INT es eficiente para contar unidades físicas donde no existen fracciones.
    stock_actual INT,
    stock_minimo INT,
    -- DATE es ideal para almacenar registros temporales sin necesidad de precisión horaria.
    fecha_ingreso DATE,
    activo TINYINT
);

-- ── SECCIÓN DML ──────────────────────────

